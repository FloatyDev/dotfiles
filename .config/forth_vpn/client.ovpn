##############################################
# Working client configuration file
# for FORTH/ICS openvpn.
#
# Version 1.0
#  201007
# Version 2.0 
#  201910
# Version 2.1
#  20191107
#  - added reneg-sec 0 to avoid renegotiation
# Version 2.2
#  20200620
#  - ca certificate change
#  Version 2.3
#   20201115
#   - change tun-mut and mssfix
#  Version 2.4
#    20240625
#    - remove topology subnet line
###############################################

#######################################################
#### CHANGE HERE
#
# In case the network you are in does not allow
# direct outgoing connections to port 443, but instead
# you are obliged to use a proxy, declare it here
#
;http-proxy-retry # retry on connection failures
;http-proxy [proxy server] [proxy port #]

#######################################################
#### YOU SHOULD NOT NEED TO TOUCH BELLOW THIS LINE ####

client
setenv CLIENT_CERT 0
auth-user-pass
static-challenge "Enter OTP Code" 1
script-security 2
keepalive 5 60
reneg-sec 0
#topology subnet
dev tun
proto tcp
remote vpn.ics.forth.gr 443
resolv-retry infinite
nobind
persist-key
persist-tun
tun-mtu 1400
mssfix 1360
verb 4
cipher DES-EDE3-CBC
# do not alter these settings.
# if auto-reconnect is enabled the otp 
# will be disabled and you will not be 
# able to connect again
auth-nocache
connect-retry 120
connect-retry-max 1
connect-timeout 120
#
#ns-cert-type server
remote-cert-tls server
#
#
comp-lzo
#
#

# ~/.bash_local — machine-specific shell config
#
# This file is sourced by ~/.bashrc but is NEVER tracked in the dotfiles repo.
# Copy this template to ~/.bash_local on each machine and fill in the values.
#
#   cp ~/.bash_local.example ~/.bash_local
#

# ─── SSH aliases ──────────────────────────────────────────────────────────────
# alias sshforth='ssh <user>@<ip>'
# alias smicro='ssh -p <port> <user>@<ip>'

# ─── VPN ──────────────────────────────────────────────────────────────────────
# alias icsvpn='sudo openvpn --config /etc/openvpn/client/client.ovpn'

# ─── API keys (never commit these) ───────────────────────────────────────────
# Load from a separate key file so the key itself isn't even in this file.
# [ -f "$HOME/.deepseek_api_key" ] && \
#     export DEEPSEEK_API_KEY=$(cat "$HOME/.deepseek_api_key" | tr -d '[:space:]')

